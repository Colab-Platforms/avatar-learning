model Assessment {
  id       String         @id @default(cuid())
  courseId String         @map("course_id")
  lessonId String?        @unique @map("lesson_id")
  type     AssessmentType @default(FINAL)

  title         String
  description   String?
  questionCount Int       @default(30) @map("question_count")

  timeLimitMinutes     Int  @map("time_limit_minutes")
  passingScorePercent  Int? @map("passing_score_percent")
  maxTabSwitchWarnings Int  @default(3) @map("max_tab_switch_warnings")
  /// FINAL only — null means unlimited (WEEKLY always unlimited regardless).
  maxAttempts          Int? @default(3) @map("max_attempts")

  isPublished Boolean @default(false) @map("is_published")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  course    Courses              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lessons?             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions AssessmentQuestion[]
  attempts  AssessmentAttempt[]

  @@index([courseId])
  @@index([courseId, type])
  @@index([isPublished])
  @@map("assessments")
}

model AssessmentQuestion {
  id           String @id @default(cuid())
  assessmentId String @map("assessment_id")

  questionText  String @map("question_text") @db.Text
  points        Int    @default(1)
  questionOrder Int    @map("question_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  options    AssessmentOption[]
  answers    AssessmentAnswer[]

  @@unique([assessmentId, questionOrder])
  @@index([assessmentId])
  @@map("assessment_questions")
}

model AssessmentOption {
  id         String @id @default(cuid())
  questionId String @map("question_id")

  optionText  String  @map("option_text") @db.Text
  isCorrect   Boolean @default(false) @map("is_correct")
  optionOrder Int     @map("option_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  question AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  AssessmentAnswer[]

  @@unique([questionId, optionOrder])
  @@index([questionId])
  @@map("assessment_options")
}

model AssessmentAttempt {
  id           String @id @default(cuid())
  userId       String @map("user_id")
  assessmentId String @map("assessment_id")

  status        AssessmentAttemptStatus @default(IN_PROGRESS)
  attemptNumber Int                     @default(1) @map("attempt_number")

  startedAt   DateTime  @default(now()) @map("started_at")
  submittedAt DateTime? @map("submitted_at")

  // Snapshotted at attempt-start so a later admin edit to Assessment.timeLimitMinutes
  // never changes the deadline of an attempt already in progress.
  timeLimitMinutes Int @map("time_limit_minutes")

  tabSwitchCount  Int  @default(0) @map("tab_switch_count")
  durationSeconds Int? @map("duration_seconds")

  score        Int?     @map("score")
  maxScore     Int?     @map("max_score")
  scorePercent Float?   @map("score_percent")
  isPassed     Boolean? @map("is_passed")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answers    AssessmentAnswer[]

  @@unique([userId, assessmentId, attemptNumber])
  @@index([userId, assessmentId])
  @@index([userId])
  @@index([assessmentId])
  @@map("assessment_attempts")
}

model AssessmentAnswer {
  id               String  @id @default(cuid())
  attemptId        String  @map("attempt_id")
  questionId       String  @map("question_id")
  selectedOptionId String? @map("selected_option_id")

  isCorrect     Boolean? @map("is_correct")
  pointsAwarded Int?     @map("points_awarded")

  answeredAt DateTime @default(now()) @map("answered_at")

  attempt        AssessmentAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption AssessmentOption?  @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("assessment_answers")
}

// ─── Direct2Hire Internship Tasks (course-scoped, 8 weeks) ───────────────────

model InternshipTask {
  id String @id @default(cuid())

  courseId String @map("course_id")

  weekNumber Int @map("week_number")

  title                String
  shortDescription     String @map("short_description")
  detailedInstructions String @map("detailed_instructions") @db.Text
  expectedDeliverables String @map("expected_deliverables") @db.Text
  estimatedHours       Int?   @map("estimated_hours")

  isPublished Boolean @default(false) @map("is_published")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  course      Courses                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attachments InternshipTaskAttachment[]
  submissions InternshipSubmission[]

  @@unique([courseId, weekNumber])
  @@index([courseId])
  @@index([courseId, isPublished])
  @@map("internship_tasks")
}

model InternshipTaskAttachment {
  id String @id @default(cuid())

  taskId String @map("task_id")

  url              String
  publicId         String @map("public_id")
  originalFilename String @map("original_filename")
  mimeType         String @map("mime_type")
  size             Int

  createdAt DateTime @default(now()) @map("created_at")

  task InternshipTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("internship_task_attachments")
}

model InternshipSubmission {
  id String @id @default(cuid())

  taskId String @map("task_id")
  userId String @map("user_id")

  status InternshipSubmissionStatus @default(UNDER_REVIEW)

  studentNotes  String? @map("student_notes") @db.Text
  adminFeedback String? @map("admin_feedback") @db.Text

  submittedAt DateTime  @default(now()) @map("submitted_at")
  reviewedAt  DateTime? @map("reviewed_at")
  reviewedBy  String?   @map("reviewed_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  task        InternshipTask                   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User                             @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer    User?                            @relation("InternshipSubmissionReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  attachments InternshipSubmissionAttachment[]

  @@unique([userId, taskId])
  @@index([taskId])
  @@index([userId])
  @@index([status])
  @@map("internship_submissions")
}

model InternshipSubmissionAttachment {
  id String @id @default(cuid())

  submissionId String @map("submission_id")

  kind SubmissionAttachmentKind

  /// Display label for links (e.g. GitHub, Figma, Loom) or file description
  label String?

  url              String
  publicId         String? @map("public_id")
  originalFilename String? @map("original_filename")
  mimeType         String? @map("mime_type")
  size             Int?

  createdAt DateTime @default(now()) @map("created_at")

  submission InternshipSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("internship_submission_attachments")
}

// ─── Direct2Hire Placement Assessment (course-scoped, retakeable) ────────────

model PlacementAssessment {
  id       String @id @default(cuid())
  courseId String @unique @map("course_id")

  title       String
  description String?

  timeLimitMinutes     Int @map("time_limit_minutes")
  passingScorePercent  Int @default(60) @map("passing_score_percent")
  questionsPerAttempt  Int @default(20) @map("questions_per_attempt")
  maxTabSwitchWarnings Int @default(3) @map("max_tab_switch_warnings")
  maxAttempts          Int @default(3) @map("max_attempts")

  isPublished Boolean @default(false) @map("is_published")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  course    Courses                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions PlacementQuestion[]
  attempts  PlacementAttempt[]
  overrides PlacementAttemptOverride[]

  @@index([isPublished])
  @@map("placement_assessments")
}

model PlacementQuestion {
  id                    String @id @default(cuid())
  placementAssessmentId String @map("placement_assessment_id")

  questionText  String @map("question_text") @db.Text
  points        Int    @default(1)
  questionOrder Int    @map("question_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  assessment PlacementAssessment @relation(fields: [placementAssessmentId], references: [id], onDelete: Cascade)
  options    PlacementOption[]
  answers    PlacementAnswer[]

  @@unique([placementAssessmentId, questionOrder])
  @@index([placementAssessmentId])
  @@map("placement_questions")
}

model PlacementOption {
  id         String @id @default(cuid())
  questionId String @map("question_id")

  optionText  String  @map("option_text") @db.Text
  isCorrect   Boolean @default(false) @map("is_correct")
  optionOrder Int     @map("option_order")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  question PlacementQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  PlacementAnswer[]

  @@unique([questionId, optionOrder])
  @@index([questionId])
  @@map("placement_options")
}

model PlacementAttempt {
  id                    String @id @default(cuid())
  userId                String @map("user_id")
  placementAssessmentId String @map("placement_assessment_id")

  status PlacementAttemptStatus @default(IN_PROGRESS)

  attemptNumber Int @default(1) @map("attempt_number")

  // Randomized subset of question IDs chosen at attempt-start, order-preserved.
  // Guarantees refreshes never reshuffle, while a fresh attempt (retake) re-randomizes.
  questionIds String[] @map("question_ids")

  startedAt       DateTime  @default(now()) @map("started_at")
  submittedAt     DateTime? @map("submitted_at")
  durationSeconds Int?      @map("duration_seconds")

  timeLimitMinutes Int @map("time_limit_minutes")

  tabSwitchCount Int @default(0) @map("tab_switch_count")

  score        Int?     @map("score")
  maxScore     Int?     @map("max_score")
  scorePercent Float?   @map("score_percent")
  isPassed     Boolean? @map("is_passed")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment PlacementAssessment @relation(fields: [placementAssessmentId], references: [id], onDelete: Cascade)
  answers    PlacementAnswer[]

  @@index([userId, placementAssessmentId])
  @@index([placementAssessmentId])
  @@map("placement_attempts")
}

model PlacementAnswer {
  id               String  @id @default(cuid())
  attemptId        String  @map("attempt_id")
  questionId       String  @map("question_id")
  selectedOptionId String? @map("selected_option_id")

  isCorrect     Boolean? @map("is_correct")
  pointsAwarded Int?     @map("points_awarded")

  answeredAt DateTime @default(now()) @map("answered_at")

  attempt        PlacementAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       PlacementQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption PlacementOption?  @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("placement_answers")
}

model PlacementAttemptOverride {
  id                    String @id @default(cuid())
  userId                String @map("user_id")
  placementAssessmentId String @map("placement_assessment_id")
  grantedById           String @map("granted_by_id")

  attemptsGranted Int    @map("attempts_granted")
  reason          String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  user       User                @relation("PlacementOverrideRecipient", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy  User                @relation("PlacementOverrideAdmin", fields: [grantedById], references: [id], onDelete: Cascade)
  assessment PlacementAssessment @relation(fields: [placementAssessmentId], references: [id], onDelete: Cascade)

  @@index([userId, placementAssessmentId])
  @@index([placementAssessmentId])
  @@map("placement_attempt_overrides")
}

model MockInterview {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  status MockInterviewStatus @default(REQUESTED)

  interviewerName String?   @map("interviewer_name")
  meetingLink     String?   @map("meeting_link") @db.Text
  scheduledAt     DateTime? @map("scheduled_at")
  durationMinutes Int?      @map("duration_minutes")
  adminNotes      String?   @map("admin_notes") @db.Text

  performanceGrade MockInterviewPerformanceGrade? @map("performance_grade")
  feedback         String?                        @db.Text
  feedbackPublishedAt DateTime?                   @map("feedback_published_at")

  completedAt DateTime? @map("completed_at")
  cancelledAt DateTime? @map("cancelled_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("mock_interviews")
}