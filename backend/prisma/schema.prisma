generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CurrentStudyLevel {
  PRIMARY_SCHOOL
  MIDDLE_SCHOOL
  HIGH_SCHOOL
  SENIOR_SECONDARY
  UNDERGRADUATE
  POSTGRADUATE
  DOCTORATE
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ResourceCategory {
  DOCUMENT
  VIDEO
  IMAGE
  OTHER
}

enum OtpType {
  REGISTER
  LOGIN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  REMOTE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum Direct2HireStatus {
  PENDING
  PAID
  REFUNDED
}

enum PaymentOrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProductType {
  COURSE
  DIRECT2HIRE
}

enum PaymentProvider {
  RAZORPAY
  CASHFREE
}

enum PaymentTransactionStatus {
  SUCCESS
  FAILED
  REFUNDED
}

enum AssessmentAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED_TIMEOUT
  AUTO_SUBMITTED_VIOLATION
}

enum AssessmentType {
  WEEKLY
  FINAL
}

enum PlacementAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED_TIMEOUT
  AUTO_SUBMITTED_VIOLATION
}

enum InternshipSubmissionStatus {
  UNDER_REVIEW
  APPROVED
  CHANGES_REQUESTED
}

enum MockInterviewStatus {
  REQUESTED
  SCHEDULED
  COMPLETED
  FEEDBACK_PUBLISHED
  CANCELLED
}

enum MockInterviewPerformanceGrade {
  GRADE_A
  GRADE_B
  GRADE_C
}

enum SubmissionAttachmentKind {
  FILE
  LINK
}

model User {
  id             String  @id @default(cuid())
  firstName      String? @map("first_name")
  lastName       String? @map("last_name")
  phoneNo        String? @unique @map("phone_no")
  address        String?
  gender         String?
  state          String?
  country        String?
  city           String?
  profileImage           String? @map("profile_image")
  profileImagePublicId   String? @map("profile_image_public_id")
  resumeUrl              String? @map("resume_url")
  resumePublicId String? @map("resume_public_id")

  currentStudyLevel CurrentStudyLevel? @map("current_studylevel")

  email    String  @unique
  password String?

  googleId     String?      @unique @map("google_id")
  authProvider AuthProvider @default(LOCAL) @map("auth_provider")

  isEmailVerified Boolean @default(false) @map("is_email_verified")
  isPhoneVerified Boolean @default(false) @map("is_phone_verified")
  isActive        Boolean @default(true) @map("is_active")
  isDeleted       Boolean @default(false) @map("is_deleted")

  isIntroVideoWatched Boolean   @default(false) @map("is_intro_video_watched")
  introVideoWatchedAt DateTime? @map("intro_video_watched_at")

  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  userRoleMappings UserRoleMapping[]
  enrolledCourses  CourseUserMapper[]
  sessions         Session[]
  otpVerifications OtpVerification[]
  passwordResets   PasswordResetToken[]

  createdCourses         Courses[]               @relation("CourseCreator")
  resourceDownloads      ResourceDownload[]
  createdInternships     Internship[]            @relation("InternshipCreator")
  internshipApplications InternshipApplication[]
  createdInvestorDocs    InvestorDocument[]      @relation("InvestorDocCreatedBy")

  direct2hireEnrollments    Direct2HireEnrollment[]
  direct2HireLead           Direct2HireLead?
  lessonProgress            LessonProgress[]
  topicProgress             TopicProgress[]
  paymentOrders             PaymentOrder[]
  counsellingProfile        CounsellingProfile?
  courseRecommendation      CourseRecommendation?
  counsellingBooking        CounsellingBooking?
  counsellingFeedback       CounsellingFeedback?
  assessmentAttempts        AssessmentAttempt[]
  placementAttempts         PlacementAttempt[]
  placementAttemptOverrides PlacementAttemptOverride[] @relation("PlacementOverrideRecipient")
  grantedPlacementOverrides PlacementAttemptOverride[] @relation("PlacementOverrideAdmin")
  internshipSubmissions     InternshipSubmission[]
  reviewedInternshipSubs    InternshipSubmission[]     @relation("InternshipSubmissionReviewer")
  mockInterview             MockInterview?

  partner         Partner?
  partnerReferral PartnerReferral?

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model OtpVerification {
  id String @id @default(cuid())

  email   String
  otpCode String  @map("otp_code")
  type    OtpType
  used    Boolean @default(false)

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model PasswordResetToken {
  id String @id @default(cuid())

  userId String  @map("user_id")
  token  String  @unique
  used   Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  userRoleMappings UserRoleMapping[]

  @@map("roles")
}

model UserRoleMapping {
  id String @id @default(cuid())

  userId String @map("user_id")
  roleId String @map("role_id")

  assignedAt DateTime @default(now()) @map("assigned_at")

  assignedBy String? @map("assigned_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_role_mapping")
}

model Session {
  id String @id @default(cuid())

  refreshToken String  @map("refresh_token")
  device       String?

  userId String @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Category {
  id String @id @default(cuid())

  name String @unique
  slug String @unique

  description String?
  thumbnail   String?

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  courses     Courses[]
  internships Internship[]

  @@index([isActive])
  @@map("categories")
}

model Courses {
  id String @id @default(cuid())

  categoryId String @map("category_id")

  title String
  slug  String @unique

  description String?
  thumbnail   String?
  heroImage   String? @map("hero_image")
  bannerImage String? @map("banner_image")

  level CourseLevel

  price Int @default(0)

  totalWeeks Int @default(1) @map("total_weeks")

  tools       String[] @default([])
  sessions    String?
  certificate Boolean  @default(false)
  rating      Float?
  reviews     String?
  startDate   String?  @map("start_date")
  seats       String?

  whatYouLearn        Json?   @map("what_you_learn")
  audience            Json?
  isDirect2HireCourse Boolean @default(false) @map("is_direct2hire_course")
  isPublished         Boolean @default(false) @map("is_published")

  createdBy String? @map("created_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id])

  creator User? @relation("CourseCreator", fields: [createdBy], references: [id])

  lessons               Lessons[]
  enrollments           CourseUserMapper[]
  paymentOrders         PaymentOrder[]
  assessments           Assessment[]
  placementAssessment   PlacementAssessment?
  counsellingSelections CounsellingBooking[]
  internshipTasks       InternshipTask[]

  @@index([categoryId])
  @@index([createdBy])
  @@index([isPublished])
  @@index([categoryId, isPublished])
  @@index([isPublished, createdAt])
  @@map("courses")
}

model CourseUserMapper {
  id String @id @default(cuid())

  userId   String @map("user_id")
  courseId String @map("course_id")

  enrolledAt DateTime @default(now()) @map("enrolled_at")

  completedAt DateTime? @map("completed_at")

  progress Int @default(0)

  isCompleted Boolean @default(false) @map("is_completed")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Courses @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_user_mapper")
}

model Lessons {
  id String @id @default(cuid())

  courseId String @map("course_id")

  weekNumber Int @map("week_number")

  title String

  description String?

  modules String[] @default([])

  duration Int?

  lessonOrder Int @map("lesson_order")

  releaseDate DateTime? @map("release_date")

  isPublished Boolean @default(false) @map("is_published")

  isFreePreview Boolean @default(false) @map("is_free_preview")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  course Courses @relation(fields: [courseId], references: [id], onDelete: Cascade)

  resources Resource[]

  lessonProgress LessonProgress[]

  topics Topics[]

  weeklyAssessment Assessment?

  @@unique([courseId, weekNumber])
  @@index([courseId])
  @@index([courseId, releaseDate])
  @@map("lessons")
}

model Topics {
  id String @id @default(cuid())

  lessonId String @map("lesson_id")

  title String

  description String?

  topicOrder Int @map("topic_order")

  duration Int?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  lesson Lessons @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  resources Resource[]

  topicProgress TopicProgress[]

  @@unique([lessonId, topicOrder])
  @@index([lessonId])
  @@map("topics")
}

model Resource {
  id String @id @default(cuid())

  lessonId String @map("lesson_id")

  topicId String? @map("topic_id")

  title String

  description String?

  category ResourceCategory

  type String

  url String

  bunnyVideoId String? @map("bunny_video_id")

  size String?

  downloads Int @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lesson Lessons @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  topic Topics? @relation(fields: [topicId], references: [id], onDelete: Cascade)

  downloadLogs ResourceDownload[]

  @@index([lessonId])
  @@index([topicId])
  @@index([category])
  @@map("resources")
}

model IntroVideo {
  id String @id @default(cuid())

  title String @default("Course Introduction")

  bunnyVideoId String? @map("bunny_video_id")

  url          String?
  thumbnailUrl String? @map("thumbnail_url")
  sizeBytes    String? @map("size_bytes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("intro_video")
}

model ResourceDownload {
  id String @id @default(cuid())

  userId     String @map("user_id")
  resourceId String @map("resource_id")

  downloadedAt DateTime @default(now()) @map("downloaded_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
  @@index([userId])
  @@index([resourceId])
  @@map("resource_downloads")
}

model Internship {
  id String @id @default(cuid())

  categoryId String @map("category_id")

  title   String
  slug    String @unique
  company String

  description String?

  domain         String?
  stipend        String?
  employmentType EmploymentType
  location       String?
  deadline       String?

  keyLearningOutcomes Json? @map("key_learning_outcomes")
  majorProject        Json? @map("major_project")
  whatYouReceive      Json? @map("what_you_receive")

  isPublished Boolean @default(false) @map("is_published")

  createdBy String? @map("created_by")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id])
  creator  User?    @relation("InternshipCreator", fields: [createdBy], references: [id])

  applications InternshipApplication[]

  @@index([categoryId])
  @@index([createdBy])
  @@index([isPublished])
  @@index([categoryId, isPublished])
  @@map("internships")
}

model InternshipApplication {
  id String @id @default(cuid())

  internshipId String @map("internship_id")
  userId       String @map("user_id")

  status ApplicationStatus @default(PENDING)

  // Snapshot of the resume at time of application — survives later profile
  // resume replacement/deletion so admins can always see what was submitted.
  resumeUrl      String? @map("resume_url")
  resumePublicId String? @map("resume_public_id")

  appliedAt DateTime @default(now()) @map("applied_at")

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, internshipId])
  @@index([userId])
  @@index([internshipId])
  @@map("internship_applications")
}

model InvestorCategory {
  id String @id @default(cuid())

  name      String
  slug      String  @unique
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  documents InvestorDocument[]

  @@index([isActive])
  @@map("investor_categories")
}

model InvestorDocument {
  id   String @id @default(cuid())
  name String @db.VarChar(300)
  url  String @db.Text

  categoryId String           @map("category_id")
  category   InvestorCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdById String @map("created_by")
  createdBy   User   @relation("InvestorDocCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([categoryId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("investor_documents")
}

model Direct2HireEnrollment {
  id     String            @id @default(cuid())
  userId String            @map("user_id")
  status Direct2HireStatus @default(PENDING)

  paidAt DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentOrders   PaymentOrder[]
  partnerReferral PartnerReferral?

  @@index([userId])
  @@map("direct2hire_enrollments")
}

model Direct2HireLead {
  id               String  @id @default(cuid())
  userId           String  @unique @map("user_id")
  fullName         String  @map("full_name")
  email            String
  phoneNumber      String  @map("phone_number")
  institutionName  String  @map("institution_name")
  currentEducation String  @map("current_education")
  city             String
  state            String
  paymentCompleted Boolean @default(false) @map("payment_completed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("direct2hire_leads")
}

enum PartnerType {
  INDIVIDUAL
  INSTITUTE
  CORPORATE
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PartnerClaimStatus {
  PENDING
  PAID
}

model Partner {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  type   PartnerType
  status PartnerStatus @default(PENDING)

  organizationName String? @map("organization_name")
  contactPerson    String? @map("contact_person")
  designation      String?
  instituteType    String? @map("institute_type")
  phone            String
  email            String

  location   String? // city (individual) or city/state (institute)
  profession String? // individual only — current role/profession
  linkedin   String? // individual only — optional LinkedIn profile URL
  website    String? // corporate only — optional company website
  purpose    String? // why they want to partner

  // KYC onboarding — required for INDIVIDUAL/INSTITUTE before admin review,
  // never collected for CORPORATE (no wallet/payout for that type).
  aadharNumber      String? @map("aadhar_number")
  aadharFileUrl     String? @map("aadhar_file_url")
  panNumber         String? @map("pan_number")
  panFileUrl        String? @map("pan_file_url")
  bankAccountNumber String? @map("bank_account_number")
  bankIfsc          String? @map("bank_ifsc")
  bankProofFileUrl  String? @map("bank_proof_file_url") // passbook or cancelled cheque

  referralCode  String? @unique @map("referral_code")
  walletBalance Int     @default(0) @map("wallet_balance")

  // Admin's note on the approve/reject decision — shown back to the
  // applicant (e.g. why a rejection happened) so they know what to fix.
  reviewNote String? @map("review_note")

  approvedAt DateTime? @map("approved_at")
  rejectedAt DateTime? @map("rejected_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals PartnerReferral[]
  claims    PartnerClaim[]

  @@index([status])
  @@map("partners")
}

model PartnerReferral {
  id        String @id @default(cuid())
  partnerId String @map("partner_id")

  referredUserId          String    @unique @map("referred_user_id")
  direct2hireEnrollmentId String?   @unique @map("direct2hire_enrollment_id")
  commissionEarned        Int       @default(0) @map("commission_earned")
  commissionRate          Int?      @map("commission_rate")
  creditedAt              DateTime? @map("credited_at")

  // Refund-safety window: commission is scheduled (not credited) at payment
  // time, and only actually paid out 10 days later by a cron sweep — by
  // then the enrollment's refund window (see Direct2HireEnrollment) has
  // closed, so a refunded student never generates a payout.
  eligibleAt    DateTime? @map("eligible_at")
  pendingAmount Int?      @map("pending_amount")
  isRefunded    Boolean   @default(false) @map("is_refunded")

  createdAt DateTime @default(now()) @map("created_at")

  partner               Partner                @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  referredUser          User                   @relation(fields: [referredUserId], references: [id], onDelete: Cascade)
  direct2hireEnrollment Direct2HireEnrollment? @relation(fields: [direct2hireEnrollmentId], references: [id])

  @@index([partnerId])
  @@index([eligibleAt])
  @@map("partner_referrals")
}

model PartnerClaim {
  id        String @id @default(cuid())
  partnerId String @map("partner_id")

  amount Int
  status PartnerClaimStatus @default(PENDING)

  requestedAt DateTime  @default(now()) @map("requested_at")
  paidAt      DateTime? @map("paid_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("partner_claims")
}

model CounsellingProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")

  careerField            String  @map("career_field")
  careerFieldOther       String? @map("career_field_other")
  futureGoal             String  @map("future_goal")
  futureGoalOther        String? @map("future_goal_other")
  careerPriority         String  @map("career_priority")
  careerPriorityOther    String? @map("career_priority_other")
  studyStream            String  @map("study_stream")
  studyStreamOther       String? @map("study_stream_other")
  planningChallenge      String  @map("planning_challenge")
  planningChallengeOther String? @map("planning_challenge_other")
  aiUnderstanding        String  @map("ai_understanding")
  aiUnderstandingOther   String? @map("ai_understanding_other")
  aiFieldImpact          String  @map("ai_field_impact")
  aiFieldImpactOther     String? @map("ai_field_impact_other")
  aiSkillBuilding        String  @map("ai_skill_building")
  aiSkillBuildingOther   String? @map("ai_skill_building_other")

  freeTimeActivity     String  @map("free_time_activity")
  freeTimeOther        String? @map("free_time_other")
  socialSetting        String  @map("social_setting")
  socialSettingOther   String? @map("social_setting_other")
  workEnvironment      String  @map("work_environment")
  workEnvironmentOther String? @map("work_environment_other")
  stressHandling       String  @map("stress_handling")
  stressHandlingOther  String? @map("stress_handling_other")
  proudMoment          String  @map("proud_moment")
  proudMomentOther     String? @map("proud_moment_other")
  aiEverydayUse        String  @map("ai_everyday_use")
  aiEverydayUseOther   String? @map("ai_everyday_use_other")
  aiCuriosity          String  @map("ai_curiosity")
  aiCuriosityOther     String? @map("ai_curiosity_other")

  personalNote String? @map("personal_note") @db.Text

  isSubmitted Boolean   @default(false) @map("is_submitted")
  submittedAt DateTime? @map("submitted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseRecommendation CourseRecommendation?

  @@map("counselling_profiles")
}

model CourseRecommendation {
  id                   String @id @default(cuid())
  userId               String @unique @map("user_id")
  counsellingProfileId String @unique @map("counselling_profile_id")

  recommendedCourseId    String @map("recommended_course_id")
  recommendedCourseSlug  String @map("recommended_course_slug")
  recommendedCourseTitle String @map("recommended_course_title")

  confidenceScore  Float?  @map("confidence_score")
  reasoning        String  @db.Text
  studentStrengths Json?   @map("student_strengths")
  growthAreas      Json?   @map("growth_areas")
  summary          String? @db.Text

  provider      String
  model         String
  promptVersion String @map("prompt_version")
  rawResponse   Json?  @map("raw_response")

  generatedAt DateTime @map("generated_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  counsellingProfile CounsellingProfile @relation(fields: [counsellingProfileId], references: [id], onDelete: Cascade)

  @@map("course_recommendations")
}

model PaymentOrder {
  id                      String             @id @default(cuid())
  userId                  String             @map("user_id")
  courseId                String?            @map("course_id")
  direct2hireEnrollmentId String?            @map("direct2hire_enrollment_id")
  productType             PaymentProductType @default(COURSE) @map("product_type")
  provider                PaymentProvider    @default(RAZORPAY)
  gatewayOrderId          String             @unique @map("gateway_order_id")
  amount                  Int
  currency                String             @default("INR")
  status                  PaymentOrderStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course                Courses?               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  direct2hireEnrollment Direct2HireEnrollment? @relation(fields: [direct2hireEnrollmentId], references: [id], onDelete: Cascade)
  transactions          PaymentTransaction[]

  @@index([courseId])
  @@index([direct2hireEnrollmentId])
  @@index([gatewayOrderId])
  @@index([status])
  @@index([userId])
  @@map("payment_orders")
}

model PaymentTransaction {
  id               String                   @id @default(cuid())
  paymentOrderId   String                   @map("payment_order_id")
  gatewayPaymentId String                   @unique @map("gateway_payment_id")
  gatewaySignature String                   @map("gateway_signature")
  paymentMethod    String?                  @map("payment_method")
  amount           Int
  status           PaymentTransactionStatus
  metadata         Json?

  createdAt DateTime @default(now()) @map("created_at")

  paymentOrder PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)

  @@index([gatewayPaymentId])
  @@index([paymentOrderId])
  @@map("payment_transactions")
}

model Contact {
