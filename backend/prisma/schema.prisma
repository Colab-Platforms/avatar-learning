generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CurrentStudyLevel {
  PRIMARY_SCHOOL
  MIDDLE_SCHOOL
  HIGH_SCHOOL
  SENIOR_SECONDARY
  UNDERGRADUATE
  POSTGRADUATE
  DOCTORATE
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ResourceCategory {
  DOCUMENT
  VIDEO
  IMAGE
  OTHER
}

enum OtpType {
  REGISTER
  LOGIN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  REMOTE
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum Direct2HireStatus {
  PENDING
  PAID
}

enum PaymentOrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProductType {
  COURSE
  DIRECT2HIRE
}

enum PaymentProvider {
  RAZORPAY
  CASHFREE
}

enum PaymentTransactionStatus {
  SUCCESS
  FAILED
  REFUNDED
}

model User {
  id                String              @id @default(cuid())
  firstName         String?             @map("first_name")
  lastName          String?             @map("last_name")
  phoneNo           String?             @unique @map("phone_no")
  address           String?
  gender            String?
  state             String?
  country           String?
  profileImage      String?             @map("profile_image")
  resumeUrl         String?             @map("resume_url")
  resumePublicId    String?             @map("resume_public_id")

  currentStudyLevel CurrentStudyLevel?  @map("current_studylevel")

  email             String              @unique
  password          String?

  googleId          String?             @unique @map("google_id")
  authProvider      AuthProvider        @default(LOCAL) @map("auth_provider")

  isEmailVerified   Boolean             @default(false) @map("is_email_verified")
  isPhoneVerified   Boolean             @default(false) @map("is_phone_verified")
  isActive          Boolean             @default(true) @map("is_active")
  isDeleted         Boolean             @default(false) @map("is_deleted")

  deletedAt         DateTime?           @map("deleted_at")

  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime?           @updatedAt @map("updated_at")

  userRoleMappings  UserRoleMapping[]
  enrolledCourses   CourseUserMapper[]
  sessions          Session[]
  otpVerifications  OtpVerification[]
  passwordResets    PasswordResetToken[]

  createdCourses    Courses[]           @relation("CourseCreator")
  resourceDownloads ResourceDownload[]
  createdInternships Internship[]        @relation("InternshipCreator")
  internshipApplications InternshipApplication[]
  createdInvestorDocs InvestorDocument[] @relation("InvestorDocCreatedBy")

  direct2hireEnrollments Direct2HireEnrollment[]
  lesson_progress lesson_progress[]
  paymentOrders          PaymentOrder[]

  @@index([email])
  @@index([isActive])
  @@map("users")
}

model OtpVerification {
  id        String   @id @default(cuid())

  email     String
  otpCode   String   @map("otp_code")
  type      OtpType
  used      Boolean  @default(false)

  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("otp_verifications")
}

model PasswordResetToken {
  id        String   @id @default(cuid())

  userId    String   @map("user_id")
  token     String   @unique
  used      Boolean  @default(false)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

model Role {
  id               String              @id @default(cuid())
  name             String             @unique
  description      String?

  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime?          @updatedAt @map("updated_at")

  userRoleMappings UserRoleMapping[]

  @@map("roles")
}

model UserRoleMapping {
  id         String      @id @default(cuid())

  userId     String      @map("user_id")
  roleId     String      @map("role_id")

  assignedAt DateTime @default(now()) @map("assigned_at")

  assignedBy String? @map("assigned_by")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])

  @@map("user_role_mapping")
}

model Session {
  id           String   @id @default(cuid())

  refreshToken String   @map("refresh_token")
  device       String?

  userId       String      @map("user_id")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([userId])
  @@index([expiresAt])

  @@map("sessions")
}

model Category {
  id           String   @id @default(cuid())

  name        String    @unique
  slug        String    @unique

  description String?
  thumbnail   String?

  isActive    Boolean   @default(true) @map("is_active")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  courses     Courses[]
  internships Internship[]

  @@index([isActive])
  @@map("categories")
}

model Courses {
    id           String      @id @default(cuid())

  categoryId   String         @map("category_id")

  title        String
  slug         String      @unique

  description  String?
  thumbnail    String?
  heroImage    String?     @map("hero_image")
  bannerImage  String?     @map("banner_image")

  level        CourseLevel

  price        Int         @default(0)

  totalWeeks   Int         @default(1) @map("total_weeks")

  tools        String[]    @default([])
  sessions     String?
  certificate  Boolean     @default(false)
  rating       Float?
  reviews      String?
  startDate    String?     @map("start_date")
  seats        String?

  whatYouLearn Json?       @map("what_you_learn")
  audience     Json?
  is_direct2hire_course Boolean @default(false)
  isPublished  Boolean     @default(false) @map("is_published")

  createdBy    String?        @map("created_by")

  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime?   @updatedAt @map("updated_at")

  category     Category    @relation(fields: [categoryId], references: [id])

  creator      User?       @relation("CourseCreator", fields: [createdBy], references: [id])

  lessons      Lessons[]
  enrollments  CourseUserMapper[]
  paymentOrders PaymentOrder[]

  @@index([categoryId])
  @@index([createdBy])
  @@index([isPublished])
  @@index([categoryId, isPublished])
  @@index([isPublished, createdAt])
  @@map("courses")
}

model CourseUserMapper {
  id           String        @id @default(cuid())

  userId       String        @map("user_id")
  courseId     String        @map("course_id")

  enrolledAt   DateTime   @default(now()) @map("enrolled_at")

  completedAt  DateTime?  @map("completed_at")

  progress     Int        @default(0)

  isCompleted  Boolean    @default(false) @map("is_completed")

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course       Courses    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])

  @@index([userId])
  @@index([courseId])

  @@map("course_user_mapper")
}

model Lessons {
  id             String         @id @default(cuid())

  courseId       String         @map("course_id")

  weekNumber     Int         @map("week_number")

  title          String

  description    String?

  modules        String[]    @default([])

  duration       Int?

  lessonOrder    Int         @map("lesson_order")

  releaseDate    DateTime?   @map("release_date")

  isPublished    Boolean     @default(false) @map("is_published")

  isFreePreview  Boolean     @default(false) @map("is_free_preview")

  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime?   @updatedAt @map("updated_at")

  course         Courses     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  resources      Resource[]

  lesson_progress lesson_progress[]
  
  @@unique([courseId, weekNumber])

  @@index([courseId])
  @@index([courseId, releaseDate])

  @@map("lessons")
}

model Resource {
    id            String             @id @default(cuid())

  lessonId      String                @map("lesson_id")

  title         String

  description   String?

  category      ResourceCategory

  type          String

  url           String

  bunnyVideoId  String?            @map("bunny_video_id")

  size          String?

  downloads     Int                @default(0)

  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  lesson        Lessons            @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  downloadLogs ResourceDownload[]
  @@index([lessonId])
  @@index([category])

  @@map("resources")
}

model ResourceDownload {
  id           String   @id @default(cuid())

  userId       String   @map("user_id")
  resourceId   String   @map("resource_id")

  downloadedAt DateTime @default(now()) @map("downloaded_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resource     Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])

  @@index([userId])
  @@index([resourceId])

  @@map("resource_downloads")
}

model Internship {
  id            String    @id @default(cuid())

  categoryId    String    @map("category_id")

  title         String
  slug          String    @unique
  company       String

  description   String?

  domain        String?
  stipend       String?
  employmentType EmploymentType
  location      String?
  deadline      String?

  keyLearningOutcomes Json?  @map("key_learning_outcomes")
  majorProject        Json?  @map("major_project")
  whatYouReceive      Json?  @map("what_you_receive")

  isPublished   Boolean   @default(false) @map("is_published")

  createdBy     String?   @map("created_by")

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")

  category      Category  @relation(fields: [categoryId], references: [id])
  creator       User?     @relation("InternshipCreator", fields: [createdBy], references: [id])

  applications  InternshipApplication[]

  @@index([categoryId])
  @@index([createdBy])
  @@index([isPublished])
  @@index([categoryId, isPublished])
  @@map("internships")
}

model InternshipApplication {
  id            String    @id @default(cuid())

  internshipId  String    @map("internship_id")
  userId        String    @map("user_id")

  status        ApplicationStatus @default(PENDING)

  // Snapshot of the resume at time of application — survives later profile
  // resume replacement/deletion so admins can always see what was submitted.
  resumeUrl       String?   @map("resume_url")
  resumePublicId  String?   @map("resume_public_id")

  appliedAt     DateTime  @default(now()) @map("applied_at")

  internship    Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, internshipId])

  @@index([userId])
  @@index([internshipId])

  @@map("internship_applications")
}

model InvestorCategory {
  id        String   @id @default(cuid())

  name      String
  slug      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  documents InvestorDocument[]

  @@index([isActive])
  @@map("investor_categories")
}

model InvestorDocument {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(300)
  url         String   @db.Text

  categoryId  String           @map("category_id")
  category    InvestorCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdById String   @map("created_by")
  createdBy   User     @relation("InvestorDocCreatedBy", fields: [createdById], references: [id])

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([categoryId])
  @@index([createdById])
  @@index([deletedAt])
  @@map("investor_documents")
}

model Direct2HireEnrollment {
  id     String            @id @default(cuid())
  userId String            @map("user_id")
  status Direct2HireStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentOrders PaymentOrder[]

  @@index([userId])
  @@map("direct2hire_enrollments")
}

model PaymentOrder {
  id                      String             @id @default(cuid())
  userId                  String             @map("user_id")
  courseId                String?            @map("course_id")
  direct2hireEnrollmentId String?            @map("direct2Hire_enrollment_id")
  productType             PaymentProductType @default(COURSE) @map("product_type")
  provider                PaymentProvider    @default(RAZORPAY)
  gatewayOrderId          String             @unique @map("gateway_order_id")
  amount                  Int
  currency                String             @default("INR")
  status                  PaymentOrderStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course                Courses?               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  direct2hireEnrollment Direct2HireEnrollment? @relation(fields: [direct2hireEnrollmentId], references: [id], onDelete: Cascade)
  transactions          PaymentTransaction[]

  @@index([courseId])
  @@index([direct2hireEnrollmentId])
  @@index([gatewayOrderId])
  @@index([status])
  @@index([userId])
  @@map("payment_orders")
}

model PaymentTransaction {
  id               String                   @id @default(cuid())
  paymentOrderId   String                   @map("payment_order_id")
  gatewayPaymentId String                   @unique @map("gateway_payment_id")
  gatewaySignature String                   @map("gateway_signature")
  paymentMethod    String?                  @map("payment_method")
  amount           Int
  status           PaymentTransactionStatus
  metadata         Json?

  createdAt DateTime @default(now()) @map("created_at")

  paymentOrder PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)

  @@index([gatewayPaymentId])
  @@index([paymentOrderId])
  @@map("payment_transactions")
}

model lesson_progress {
  id           String   @id
  user_id      String
  lesson_id    String
  completed_at DateTime @default(now())

  lessons      Lessons  @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  users        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id])
  @@index([lesson_id])
  @@index([user_id])
}